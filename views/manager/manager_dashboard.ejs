
<%- include('../layouts/header.ejs') %>

<%- include('../layouts/manager_nav.ejs') %>

        <!-- Page content-->
    <section class="bg-secondary-subtle">
        <div class="container-xl">
            <div class="row py-5">
                <div class="col d-flex flex-column align-items-start gap-2">
                    <h2 class="fw-normal display-4">Records</h2>
                    <p class="fs-4 fw-normal mb-5">Paragraph of text beneath the heading to explain the heading. We'll add onto it with
                        another sentence and probably just keep going until we run out of words.</p>
                </div>
    <div class="col-lg-12">
    <div class="row">

    <% if(!data || data.length===0){ %>

    <div class="col-12 text-center">
        <h4 class="text-danger">No Records Found</h4>
    </div>

    <% } else { %>

    <% data.forEach((emp)=>{ %>

        <div class="col-lg-4">
            <div class="card mb-4 border-0 bg-transparent">
                <div class="card-body p-4 border-0 bg-light-blue shadow-lg rounded-4">
                    <div class="lead fw-normal fs-4 text-black mb-3">
                        <%= new Date(emp.createdAt).toDateString() %>
                    </div>
                    <h2 class="card-title fs-3 text-truncate fw-semibold mb-3">
                        <%= emp.title %>
                    </h2>
                    <p class="card-text lead fs-4 text-truncate fw-normal">
                        <%= emp.description %>
                    </p>
                    <div class="d-lg-block d-block gap-2 d-md-flex justify-content-center">
                        <a class="btn btn-primary btn-lg me-md-2" href="/edit/record/<%= emp._id %>"><i class="bi bi-pen me-2"></i>Edit Record</a>
                        <a class="btn btn-danger btn-lg" data-bs-toggle="modal" data-bs-target="#exampleModal"><i class="bi bi-trash me-2"></i>Delete Record</a>

                        <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                            <!-- Vertically centered modal -->
                            <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content rounded-4 shadow-lg bg-light-blue p-2">
                                <div class="modal-header border-bottom-0">
                                    <h1 class="fs-3 text-truncate text-primary fw-semibold mb-3">Oops, Access Denied!!</h1>
                                    <hr class="mt-2">
                                    <button type="button" class="btn-close fs-4" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body py-0">
                                    <p class="text-black lead fs-3 fw-normal">Sorry, You Dont have access to delete Record</p>
                                </div>
                                <div class="modal-footer flex-column align-items-stretch w-100 gap-2 pb-3 border-top-0">
                                     <button type="button" class="btn btn-lg btn-primary" data-bs-dismiss="modal">Close</button> </div>
                            </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    <% }) %>
        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </section>

<%- include('../layouts/footer.ejs') %>