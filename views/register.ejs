
<%- include('layouts/header') %>

    <section class="bg-body-secondary py-5">
        <div class="container px-5 my-5 px-5">
            <div class="row p-4 justify-content-center">
                <div class="px-4 text-center">
                    <h1 class="display-5 fw-bold text-body-emphasis mb-4">Role-Based Access Control (RBAC)</h1>
                    <div class="col-lg-9 mx-auto">
                        <p class="lead fw-semibold mb-4">Role-Based Access Control (RBAC) stands as a pivotal pillar in ensuring robust
                            application security. Offering a
                            systematic framework, RBAC empowers organisations and applications to meticulously govern and limit resource
                            access in
                            accordance with users’ designated roles</p>
                    </div>
                </div>
                <div class="col-lg-6 col-12 my-0 py-3">
                    <form action="/create/register" class="p-4 border-0 rounded-4 bg-light-blue shadow-lg" method="post">
                        <div class="text-center">
                            <h2 class="fw-semibold fs-2 mb-4">Please register here</h2>
                            <hr class="mt-3">
                        </div>
                        <!-- Name input-->
                        <div class="my-4">
                            <input class="form-control form-control-lg mb-3" name="name" type="text"
                                placeholder="Enter your name..." required>
                        </div>
                        <!-- Email address input-->
                        <div class="my-4">
                            <input class="form-control form-control-lg mb-3" name="email" type="email"
                                placeholder="name@example.com" required>
                        </div>
                        <!-- Phone input-->
                        <div class="my-4">
                            <input class="form-control form-control-lg mb-3" name="phone" type="text"
                                placeholder="your Phone Number" required>
                        </div>
                        <!-- Password input-->
                        <div class="my-4">
                            <input class="form-control form-control-lg mb-3" name="password" type="password"
                                placeholder="Enter Your Password" required>
                        </div>
                        <div class="my-4">
                            <select class="form-select form-select-lg mb-3" aria-label="Large select example" required>
                                <option selected>Choose Role</option>
                                <option value="employee">Employee</option>
                                <option value="manager">Manager</option>
                                <option value="admin">Admin</option>
                            </select>
                        </div>
                        <!-- Submit Button-->
                        <div class="d-grid">
                            <button class="btn btn-primary btn-lg" type="submit">Register User</button>
                        </div>
                        <hr class="mt-3">
                        <h5 class="text-black text-center fw-normal fs-4">Already have an account? Please <a
                                class="text-primary text-decoration-none" href="/login/view">Login</a></h5>
                    </form>
                </div>
            </div>
        </div>
    </section>